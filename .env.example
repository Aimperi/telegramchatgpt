# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (получить на platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs API Key (получить на elevenlabs.io/app/developers)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# xAI API Key для Grok Image Generation (получить на console.x.ai)
XAI_API_KEY=your_xai_api_key_here

# OpenRouter API Key (получить на openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# CryptoCloud Payment (получить на cryptocloud.plus)
CRYPTOCLOUD_API_KEY=your_cryptocloud_api_key_here
CRYPTOCLOUD_SHOP_ID=your_cryptocloud_shop_id_here

# Lava.top Card Payment (получить на app.lava.top/integrations/public-api)
LAVA_API_KEY=your_lava_api_key_here
LAVA_OFFER_ID=your_lava_offer_id_here

# PostgreSQL Database URL (опционально, предоставляется Railway при добавлении PostgreSQL addon)
# DATABASE_URL=postgresql://user:password@host:port/database

# Опциональные переменные для webhook режима
# WEBHOOK_URL=https://your-app.railway.app
# PORT=8000
